#jinja2: lstrip_blocks: "True"
- path: /system/lldp
  operation: replace
  value:
    admin-state: {{ system.lldp["admin-state"] | default('enable') }}
- path: /system/information
  operation: replace
  value:
    location: {{ system.information.location | default('n/a') }}
    contact: {{ system.information.contact | default('n/a') }}
- path: /system/network-instance/protocols/bgp-vpn
  operation: replace
  value:
    bgp-instance:
      - id: 1
- path: /system/mtu
  operation: replace
  value:
    default-ip-mtu: {{ system.mtu["default-ip-mtu"] | default(9214) }}
{% if system.mtu is defined and "default-l2-mtu" in system.mtu %}
    default-l2-mtu: {{ system.mtu["default-l2-mtu"] }}
{% endif %}
    default-port-mtu: {{ system.mtu["default-port-mtu"] | default(9232) }}
- path: /system/event-handler
  operation: replace
  value:
{% if system["oper-group"] | default({}, True) | length > 0 %}
    instance:
      - name: oper-group
        admin-state: enable
        options:
          object:
            - name: "down-links"
              values:
  {% for v in system["oper-group"]["down-links"] %}
                - {{ v }} 
  {% endfor %}
            - name: hold-down-time
              value: {{ system["oper-group"]["hold-down-time"] | default(10000) }}
            - name: required-up-uplinks
              value: {{ system["oper-group"]["min-uplinks"] | default(1) }}
        paths:
  {% for p in system["oper-group"]["monitor-paths"] %}
          - {{ p }}
  {% endfor %}
        upython-script: oper-group.py
{% else %}
    {}
{% endif %}
- path: /system/banner
  operation: replace
  value:
    motd-banner: {{ system.banner.motd | default('""') }}
    login-banner: {{ system.banner.login | default('""') }}
- path: /system/ntp
  operation: replace
  value:
{% if system.ntp | default({}, True) | length > 0 %}
    admin-state: {{ system.ntp["admin-state"] | default('enable') }}
    network-instance: {{ system.ntp["network-instance"] | default('mgmt') }}
    {% if system.ntp.servers | default({}) | length > 0 %}
    server:
      {% for srv, srv_spec in system.ntp.servers.items() %}
      - address: {{ srv }}
        prefer: {{ srv_spec.prefer | default(False) }}
        iburst: {{ srv_spec.iburst | default(False) }}
      {% endfor %}
    {% endif %}
{% else %}
    {}
{% endif %}
{% set ES = namespace(found = false) %}
{% if system.ethernet_segments is defined and system.ethernet_segments is not none %}
  {% for es, es_prop in system.ethernet_segments.items() %}
    {% if es_prop._state | default('present') == 'present' %}
      {% set ES.found = true %}
    {% endif %}
  {% endfor %}
{% endif %}
{% if ES.found %}
- path: /system/network-instance/protocols/evpn/ethernet-segments/bgp-instance[id=1]
  operation: replace
  value:
    ethernet-segment:
  {% for es, es_prop in system.ethernet_segments.items() %}
    {% if es_prop._state | default('present') == 'present' %}
      - name: {{ es }}
        admin-state: {{ es_prop.admin_state|default("enable") }}
        esi: {{ es_prop.esi }}
        multi-homing-mode: {{ es_prop.mh_mode|default("all-active") }}
        {% if es_prop.mh_mode|default("all-active") == "single-active" %}
        df-election:
          algorithm:
            preference-alg: {}
            type: preference
          interface-standby-signaling-on-non-df: {}
        {% endif %}
        interface:
          - ethernet-interface: {{ es_prop.interface }}
    {% endif %}
  {% endfor %}
{% endif %}
