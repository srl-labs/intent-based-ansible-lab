{
    "type": "object",
    "properties": {
        "ntp": {
            "type": "object",
            "properties": {
                "admin-state": {
                    "type": "string",
                    "enum": ["enable", "disable"]
                },
                "network-instance": {
                    "type": "string"
                },
                "servers": {
                    "type": "object",
                    "patternProperties": {
                        ".+": {
                            "type": "object",
                            "properties": {
                                "prefer": {
                                    "type": "boolean"
                                },
                                "iburst": {
                                    "type": "boolean"
                                
                                }
                            }
                        }
                    }
                }
            }
        },
        "mtu": {
            "type": "object",
            "properties": {
                "default-ip-mtu": {
                    "type": "number",
                    "minimum": 1280,
                    "maximum": 9486
                },
                "default-l2-mtu": {
                    "type": "number",
                    "minimum": 1500,
                    "maximum": 9500
                },
                "default-port-mtu": {
                    "type": "number",
                    "minimum": 1500,
                    "maximum": 9500
                }
            }
        },
        "lldp": {
            "type": "object",
            "properties": {
                "admin-state": {
                    "type": "string",
                    "enum": ["enable", "disable"]
                }
            }
        },
        "oper-group": {
            "type": "object",
            "properties": {
                "monitor-paths": {
                    "type": "array",
                    "items": {
                        "type": "string"
                    },
                    "minItems": 1
                },
                "down-links": {
                    "type": "array",
                    "items": {
                        "type": "string"
                    },
                    "minItems": 1
                },
                "hold-down-time": {
                    "type": "number",
                    "minimum": 1000,
                    "maximum": 120000
                },
                "min-uplinks": {
                    "type": "number",
                    "minimum": 1,
                    "maximum": 8
                }
            }
        },
        "information": {
            "type": "object",
            "properties": {
                "location": {
                    "type": "string"
                },
                "contact": {
                    "type": "string"
                }
            }
        }
    }
}
